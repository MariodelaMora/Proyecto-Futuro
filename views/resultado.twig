{% extends 'layout.twig' %}

{% block body %}
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

<div class="min-h-screen flex items-center justify-center px-5 py-10">
    <div class="max-w-2xl w-full text-center bg-white/85 backdrop-blur-2xl p-8 md:p-12 rounded-[2rem] shadow-2xl border border-white transform transition-all animate__animated animate__zoomIn">

        <div class="w-52 h-52 mx-auto rounded-full p-2 bg-gradient-to-br from-pink-500 via-yellow-300 to-green-400 mb-8 animate__animated animate__pulse animate__infinite">
            <img src="/images/san-vicente-beso.jpg" class="w-full h-full object-cover rounded-full border-8 border-white" alt="">
        </div>

        <h1 class="text-5xl md:text-7xl font-black text-gray-900 mb-4 leading-none">
            Empieza lo nuestro ❤️
        </h1>

        <div class="space-y-4 mb-8">
            <p class="text-xl text-gray-700 font-bold">
                Oficialmente novios. Ahora toca hacerlo bonito de verdad.
            </p>
            <div class="bg-green-50 p-4 rounded-2xl border border-green-200">
                <p class="text-green-800 font-mono text-sm">
                    > status: OFICIALMENTE NOVIOS <br>
                    > partner_1: Mario <br>
                    > partner_2: ella <br>
                    > connection: INESTABLEMENTE FELIZ
                </p>
            </div>
        </div>

        <p class="text-3xl">❤️🥰✨</p>

        <div class="mt-8 pt-6 border-t border-gray-100 text-gray-400 text-xs">
            ID de transacción: {{ "now"|date("Ymd-His") }}
        </div>
</div>
</div>

<script>
    // Lanzamos confeti nada más cargar la página
    var duration = 5 * 1000;
    var animationEnd = Date.now() + duration;
    var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 9999 };

    function randomInRange(min, max) {
      return Math.random() * (max - min) + min;
    }

    var interval = setInterval(function() {
      var timeLeft = animationEnd - Date.now();

      if (timeLeft <= 0) {
        return clearInterval(interval);
      }

      var particleCount = 50 * (timeLeft / duration);
      // desde los lados
      confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
      confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
    }, 250);
</script>
{% endblock %}
