{% extends 'layout.twig' %}

{% block body %}
<div id="quiz-app" class="max-w-2xl w-full mx-4 relative">
    <!-- Contenedor Principal -->
    <div class="bg-white/30 backdrop-blur-xl p-8 md:p-12 rounded-[2rem] shadow-2xl border border-white/40 relative z-10">

        <!-- Barra de Progreso -->
        <div class="w-full bg-black/10 h-1.5 mb-8 rounded-full">
            <div id="progress" class="bg-gradient-to-r from-pink-500 to-violet-500 h-full transition-all duration-700 w-0"></div>
        </div>

        <!-- Área de Preguntas -->
        <div id="question-container">
            <span id="step-text" class="text-xs uppercase tracking-widest text-indigo-800 font-bold">Iniciando sistema...</span>
            <h2 id="question-title" class="text-2xl md:text-3xl font-semibold text-gray-900 mt-2 mb-8 leading-tight"></h2>

            <div id="options" class="grid gap-4">
                <!-- Botones generados por JS -->
            </div>
        </div>

        <!-- MODAL DE RECOMPENSA (Acierto) -->
        <div id="reward-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
            <div class="bg-white/90 p-6 rounded-3xl max-w-md w-full shadow-2xl transform scale-95 transition-transform duration-300" id="modal-content">
                <img id="reward-img" src="" class="w-full h-64 object-cover rounded-2xl mb-4 shadow-lg">
                <p id="reward-text" class="text-gray-800 italic text-center mb-6 px-2 leading-relaxed"></p>
                <button onclick="nextStep()" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl transition-colors">
                    Continuar el viaje ✨
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const quizData = [
        {
            q: "¿Cuándo es el cumpleaños de Mario?",
            options: ["26 de Marzo", "27 de Marzo", "27 de Abril", "17 de Marzo"],
            correct: 1,
            img: "/images/cumple-tarta.jpg",
            msg: "Me hiciste sentir súper especial en mi día; es algo que no había sentido nunca y nunca se me va a olvidar."
        },
        {
            q: "¿Cuál fue nuestro primer viaje de 'locura' donde fuimos los más felices?",
            options: ["Oviedo", "Gijón", "San Vicente de la Barquera", "Santander"],
            correct: 2,
            img: "/images/sanvi-loca.jpg",
            msg: "Ese viaje me demostró que contigo hasta el plan más improvisado es perfecto."
        },
        {
            q: "¿Qué tiene de especial la fecha de hoy, 28 de Junio?",
            options: ["Es un domingo de verano", "Hace 1 año que nos conocimos", "Es el día que te diré algo importante", "La B y la C son correctas"],
            correct: 3,
            img: "/images/fiesta.jpg",
            msg: "Quién nos diría ese día, que metiste en la resi a un pavo que te caía mal y que dijiste que no dejarías ni dormir contigo, que estarías así ahora... jaja. Y quién me lo diría a mí también, que en esa misma situación yo, un chico que nunca tuvo novia ni sintió nada real por nadie, estaría así contigo. Por eso, quiero que esto deje de ser un juego..."
        }
    ];

    let current = 0;

    function renderQuestion() {
        const data = quizData[current];
        document.getElementById('step-text').innerText = `Recuerdo ${current + 1} de ${quizData.length}`;
        document.getElementById('question-title').innerText = data.q;
        document.getElementById('progress').style.width = `${(current / quizData.length) * 100}%`;

        const optsContainer = document.getElementById('options');
        optsContainer.innerHTML = '';

        data.options.forEach((opt, i) => {
            const btn = document.createElement('button');
            btn.className = "text-left p-4 rounded-2xl border border-white/50 bg-white/20 hover:bg-white/50 transition-all text-gray-800 font-medium shadow-sm hover:shadow-md";
            btn.innerText = opt;
            btn.onclick = () => checkAnswer(i);
            optsContainer.appendChild(btn);
        });
    }

    function checkAnswer(idx) {
        if (idx === quizData[current].correct) {
            showReward();
        } else {
            alert("¡Error de sistema! Revisa tus recuerdos... (Pista: Piénsalo bien ❤️)");
        }
    }

    function showReward() {
        const modal = document.getElementById('reward-modal');
        const content = document.getElementById('modal-content');
        document.getElementById('reward-img').src = quizData[current].img;
        document.getElementById('reward-text').innerText = `"${quizData[current].msg}"`;

        modal.classList.remove('hidden');
        setTimeout(() => content.classList.remove('scale-95'), 10);
    }

    function nextStep() {
        current++;
        document.getElementById('reward-modal').classList.add('hidden');

        if (current < quizData.length) {
            renderQuestion();
        } else {
            // Transición final a la página de la pregunta
            window.location.href = "/la-pregunta";
        }
    }

    renderQuestion();
</script>
{% endblock %}