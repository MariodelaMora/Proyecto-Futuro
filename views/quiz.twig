<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Para mi persona favorita ❤️</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

<div id="quiz-container" class="container">

    <!-- 1. Preguntas -->
    <div id="question-card" class="card text-center">
        <h3 id="question-text" class="fw-bold mb-4" style="color: #590d22;"></h3>
        <div class="image-wrapper mb-4">
            <img id="question-image" src="" class="img-fluid">
        </div>
        <div id="options-container" class="d-grid gap-3"></div>
    </div>

    <!-- 2. Feedback -->
    <div id="feedback-screen" class="card text-center d-none">
        <div class="image-wrapper mb-3">
            <img id="feedback-image" src="" class="img-fluid">
        </div>
        <p id="feedback-message" class="italic-love"></p>
        <button onclick="nextQuestion()" class="btn btn-heart">Siguiente recuerdo ❤️</button>
    </div>

    <!-- 3. Final -->
    <div id="final-screen" class="card text-center d-none">
        <div class="image-wrapper mb-4">
            <img src="/images/sanvi-loca.jpg" class="img-fluid">
        </div>
        <h2 class="fw-bold" style="color: #ff4d6d;">Entonces...</h2>
        <p class="lead mb-4">¿Te ha convencido ya este pavo para ser su novia?</p>
        <div class="d-flex justify-content-center gap-3">
            <button id="btn-si" class="btn btn-success btn-lg px-4 fw-bold">SÍ! 🌹</button>
            <button id="btn-no" class="btn btn-light btn-lg px-4">No</button>
        </div>
    </div>

</div>

<script src="/javascripts/script.js"></script>
</body>
</html>