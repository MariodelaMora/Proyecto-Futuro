{% extends 'layout.twig' %}

{% block body %}
    <div class="container mx-auto py-12 px-4">
        <div class="text-center mb-16">
            <h1 class="text-5xl font-black text-white drop-shadow-lg inline-block border-b-4 border-white pb-2">Nuestra Historia</h1>
            <p class="text-white mt-4 font-medium italic">Un recorrido por los mejores commits de mi vida...</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for hito in hitos %}
                <div class="group relative">
                    <div class="bg-white/40 backdrop-blur-md rounded-3xl p-4 shadow-xl border border-white/50 transform transition-all duration-500 group-hover:-translate-y-2 group-hover:rotate-1">

                        <div class="relative overflow-hidden rounded-2xl mb-4">
                            {% if hito.tipo == 'imagen' %}
                                <img src="{{ hito.src }}" class="w-full h-64 object-cover transform transition-transform duration-700 group-hover:scale-110">
                            {% elseif hito.tipo == 'video' %}
                                <video controls class="w-full h-64 object-cover rounded-2xl">
                                    <source src="{{ hito.src }}">
                                </video>
                            {% endif %}

                            <div class="absolute top-3 right-3 bg-pink-500/80 backdrop-blur-sm text-white text-xs font-bold px-3 py-1 rounded-full">
                                {{ hito.fecha }}
                            </div>
                        </div>

                        <h3 class="text-xl font-bold text-gray-800 mb-2">{{ hito.titulo }}</h3>
                        <p class="text-gray-700 text-sm italic leading-relaxed">"{{ hito.desc }}"</p>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="text-center mt-20">
            <a href="/la-pregunta" class="bg-white text-pink-500 font-black py-5 px-14 rounded-full text-2xl shadow-2xl hover:bg-pink-50 transition-all transform hover:scale-110 active:scale-95 inline-block">
                CONTINUAR 🚀
            </a>
        </div>
    </div>
{% endblock %}