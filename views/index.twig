{% extends 'layout.twig' %}

{% block body %}
  <main class="min-h-screen px-5 py-8 flex items-center justify-center">
    <section class="w-full max-w-5xl grid lg:grid-cols-[1fr_0.85fr] gap-8 items-center animate__animated animate__fadeIn">
      <div class="text-white drop-shadow-lg">
        <p class="uppercase tracking-[0.35em] text-sm font-black mb-5">archivo privado</p>
        <h1 class="text-5xl md:text-7xl font-black leading-none mb-6">Mario's Vault</h1>
        <p class="max-w-xl text-lg md:text-xl font-semibold leading-relaxed text-white/95">
          Has llegado a una prueba hecha solo para ti. Cada respuesta desbloquea un recuerdo, y el final no se puede ver antes de tiempo.
        </p>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 bg-white/30 blur-2xl rounded-full"></div>
        <div class="relative bg-white/28 backdrop-blur-2xl p-6 md:p-8 rounded-[2rem] border border-white/40 shadow-2xl">
          <div class="grid grid-cols-3 gap-3 mb-7">
            <img src="/images/fiesta.jpg" class="h-28 w-full object-cover rounded-2xl rotate-[-4deg] shadow-lg" alt="">
            <img src="/images/san-vicente-beso.jpg" class="h-32 w-full object-cover rounded-2xl translate-y-4 shadow-lg" alt="">
            <img src="/images/cumple-tarta.jpg" class="h-28 w-full object-cover rounded-2xl rotate-[4deg] shadow-lg" alt="">
          </div>
          <div class="bg-white/80 rounded-3xl p-5 text-center">
            <p class="text-gray-700 font-bold mb-4">Verificación emocional necesaria</p>
            <a href="/quiz" class="block w-full bg-gray-950 text-white font-black py-5 rounded-2xl shadow-xl transition-all hover:scale-[1.02] active:scale-95 animate__animated animate__pulse animate__infinite">
              INICIAR PRUEBA
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
{% endblock %}
