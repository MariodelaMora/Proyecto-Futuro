{% extends 'layout.twig' %}

{% block body %}
  <div class="max-w-lg w-full mx-4 text-center">
    <!-- Contenedor con efecto cristal -->
    <div class="bg-white/40 backdrop-blur-xl p-10 md:p-16 rounded-[3rem] shadow-2xl border border-white/50 transform transition-all">

      <!-- Icono o imagen superior (opcional) -->
      <div class="mb-6 inline-block p-4 bg-white/50 rounded-full shadow-inner">
        <span class="text-4xl">🧠</span>
      </div>

      <h1 class="text-4xl font-black text-gray-800 mb-6 uppercase tracking-tighter">
        The Mario Challenge
      </h1>

      <p class="text-lg text-gray-700 mb-10 leading-relaxed font-medium">
        ¿Crees que me conoces bien? He preparado un pequeño sistema de verificación de memoria para ponerte a prueba.
        <br><span class="text-sm italic opacity-70">(Nivel de dificultad: Leyenda)</span>
      </p>

      <!-- AQUÍ ESTÁ EL CAMBIO CLAVE: href="/quiz" -->
      <a href="/quiz" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-5 px-12 rounded-full transition-all transform hover:scale-110 shadow-xl active:scale-95">
        ACEPTAR EL RETO 🚀
      </a>
    </div>
  </div>
{% endblock %}