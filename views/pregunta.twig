{% extends 'layout.twig' %}

{% block body %}
    <div class="relative min-h-[90vh] flex items-center justify-center p-6">
        <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover opacity-30 z-0">
            <source src="/videos/mimos.mp4" type="video/mp4">
        </video>

        <div class="relative z-10 w-full max-w-sm text-center animate__animated animate__fadeInUp">
            <div class="bg-white/10 backdrop-blur-md p-10 rounded-[3rem] border border-white/20 shadow-2xl">
                <h2 class="text-indigo-900 font-black tracking-[0.2em] text-xs mb-6 uppercase">Un año después...</h2>
                <h1 class="text-4xl font-bold text-gray-900 mb-12 leading-tight">¿Quieres ser mi novia oficialmente?</h1>

                <div class="space-y-6">
                    <form action="/respuesta" method="POST">
                        <input type="hidden" name="decision" value="si">
                        <button class="w-full bg-green-500 text-white font-black py-6 rounded-3xl shadow-xl text-xl animate__animated animate__heartBeat animate__infinite">
                            SÍ, QUIERO ❤️
                        </button>
                    </form>

                    <button id="no-btn" class="text-gray-500 font-bold text-sm opacity-50 py-2">
                        No (Error de sistema)
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        const no = document.getElementById('no-btn');
        no.addEventListener('touchstart', (e) => {
            e.preventDefault();
            no.style.position = 'absolute';
            no.style.left = Math.random() * 80 + '%';
            no.style.top = Math.random() * 80 + '%';
        });
    </script>
{% endblock %}